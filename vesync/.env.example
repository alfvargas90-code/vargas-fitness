# VeSync smart-scale sync — copy to `.env` and fill in.
# .env is gitignored; never commit it.

# Your VeSync ACCOUNT login (the email/password you use in the VeSync app),
# NOT the scale's model name. pyvesync logs in with these and reuses the
# session token to hit the fat-scale endpoint directly.
VESYNC_EMAIL=you@example.com
VESYNC_PASSWORD=your-vesync-app-password

# Optional. Leave blank to auto-detect the first scale found in your account.
# After the first run, sync.py prints the scale's cid — paste it here to pin it
# (useful if you have more than one VeSync device).
VESYNC_DEVICE_ID=

# IANA timezone used for auth + reading timestamps. Default America/Chicago.
VESYNC_TIMEZONE=America/Chicago
